# Required: PostgreSQL connection string
# Free tier: https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@host/dbname

# Required: AI provider key (pick one or both)
# Google Gemini — free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# GitHub integration
# Fine-grained PAT: pull_requests: write, contents: read
GITHUB_TOKEN=your_github_pat_here

# Webhook HMAC secret — must match what you set in GitHub webhook settings
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
